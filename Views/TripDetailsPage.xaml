<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Planer_podróży.TripDetailsPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label
                x:Name="tripNameLabel"
                FontSize="28"
                FontAttributes="Bold" />

            <Label
                x:Name="cityLabel"
                FontSize="20" />

            <Label
                x:Name="dateLabel"
                FontSize="18" />

            <Label
                x:Name="budgetLabel"
                FontSize="18" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>